# Supabase project URL. This identifier is safe to expose.
NEXT_PUBLIC_SUPABASE_URL=

# Public browser key used with Row Level Security. This is not the service-role key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret. Never expose this value in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Public Sanity configuration used by the website and embedded Studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=

# Server-only Viewer token. Never prefix this variable with NEXT_PUBLIC_.
SANITY_API_READ_TOKEN=

# Revolut server credentials. Never prefix either secret with NEXT_PUBLIC_.
REVOLUT_API_SECRET=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_API_BASE_URL=

# Revolut Merchant API plan variation IDs.
REVOLUT_MONTHLY_PLAN_ID=
REVOLUT_ANNUAL_PLAN_ID=

# Hosted Revolut payment links. These are intentionally public URLs.
NEXT_PUBLIC_REVOLUT_MONTHLY_PAYMENT_LINK=
NEXT_PUBLIC_REVOLUT_ANNUAL_PAYMENT_LINK=

# Canonical application URL, without a trailing slash.
NEXT_PUBLIC_SITE_URL=

# Supported values: revolut_api or revolut_payment_links.
PAYMENT_PROVIDER_MODE=

# Server-only market-data configuration. Never use NEXT_PUBLIC_ for these.
# Supported today: development (non-production fixtures) or generic_http.
MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=
MARKET_DATA_API_BASE_URL=
MARKET_DATA_TIMEOUT_MS=5000
MARKET_DATA_CACHE_SECONDS=60

# Economic event source. Use development only outside production; production reads verified Supabase rows.
ECONOMIC_DATA_PROVIDER=
ECONOMIC_CACHE_SECONDS=300

# Watchlists and server-side smart alert evaluation
ALERT_CRON_SECRET=
ALERT_EVALUATION_BATCH_SIZE=25
ALERT_DATA_MAX_AGE_SECONDS=900
ALERT_DEFAULT_COOLDOWN_MINUTES=60
ALERT_EMAIL_PROVIDER=disabled

# Server-only AI Assistant provider. Use development only outside production.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_ASSISTANT_MODEL=
OPENAI_CLASSIFIER_MODEL=
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=700
AI_MAX_INPUT_CHARACTERS=4000
AI_MAX_CONTEXT_CHARACTERS=16000
AI_FREE_DAILY_LIMIT=5
AI_PREMIUM_DAILY_LIMIT=50
AI_MAX_CONCURRENT_REQUESTS=2
AI_CONVERSATION_RETENTION_DAYS=180

# Optional reviewed cost estimates in currency units per million tokens.
AI_INPUT_COST_PER_MILLION=
AI_OUTPUT_COST_PER_MILLION=

# Trading Academy server behavior. These are configuration values, not secrets.
ACADEMY_VIDEO_COMPLETION_PERCENT=80
ACADEMY_VIDEO_END_THRESHOLD_SECONDS=30
ACADEMY_MAX_BOOKMARKS_PER_USER=250
ACADEMY_MAX_NOTES_PER_USER=500
ACADEMY_MAX_NOTE_LENGTH=5000
ACADEMY_PROGRESS_REMINDER_DAYS=7
ACADEMY_CERTIFICATE_VERIFICATION_BASE_URL=
