# Supabase project URL. This identifier is safe to expose, but the newsletter
# implementation reads it only from the server-side API route.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Server-only secret. Add this to your hosting provider's encrypted environment
# variables and never expose it in client components or browser code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
